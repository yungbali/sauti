{
  "name": "sauti-media-baas",
  "version": "1.0.0",
  "description": "Backend-as-a-Service for media management and delivery optimized for African markets",
  "main": "index.js",
  "scripts": {
    "start": "node src/production-index.js",
    "start:gc": "node --expose-gc src/production-index.js",
    "dev": "nodemon src/production-index.js",
    "dev:gc": "nodemon --expose-gc src/production-index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "generate:postman": "node scripts/generate-postman-collection.js",
    "publish:postman": "node scripts/publish-postman-collection.js",
    "docs:postman": "npm run generate:postman && npm run publish:postman"
  },
  "keywords": [
    "media",
    "streaming",
    "baas",
    "africa",
    "mux"
  ],
  "author": "Sauti Media",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.848.0",
    "@aws-sdk/client-mediaconvert": "^3.848.0",
    "@aws-sdk/client-s3": "^3.859.0",
    "@aws-sdk/client-secrets-manager": "^3.859.0",
    "@aws-sdk/client-sts": "^3.848.0",
    "@aws-sdk/s3-request-presigner": "^3.859.0",
    "@mux/mux-node": "^12.3.0",
    "@supabase/supabase-js": "^2.53.0",
    "axios": "^1.10.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "http-status-codes": "^2.3.0",
    "joi": "^17.13.3",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "nodemailer": "^7.0.5",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.11.3",
    "puppeteer": "^22.15.0",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "ws": "^8.18.3",
    "xmldom": "^0.6.0"
  },
  "devDependencies": {
    "chai": "^5.2.1",
    "eslint": "^8.56.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "proxyquire": "^2.1.3",
    "sinon": "^21.0.0",
    "supertest": "^6.3.3",
    "vitest": "^1.1.0"
  }
}
