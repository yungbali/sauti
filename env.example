# Sauti Media BaaS Environment Configuration
# This file contains minimal environment variables when using AWS Secrets Manager

# Environment
NODE_ENV=production

# AWS Configuration
AWS_REGION=us-west-2

# Enable AWS Secrets Manager (set to 'true' to use AWS Secrets Manager instead of env vars)
USE_AWS_SECRETS_MANAGER=true

# Server Configuration (can be overridden by AWS Secrets Manager)
PORT=3000
API_PREFIX=/v1
CORS_ORIGINS=*

# Logging (can be overridden by AWS Secrets Manager)
LOG_LEVEL=info
LOG_FORMAT=json

# Optional: Override specific values (these will take precedence over AWS Secrets Manager)
# JWT_SECRET=your-jwt-secret-here
# MUX_TOKEN_ID=your-mux-token-id
# MUX_TOKEN_SECRET=your-mux-token-secret
# S3_BUCKET=your-s3-bucket-name

# Development overrides (only for local development)
# STORAGE_PROVIDER=local
# LOCAL_STORAGE_PATH=./storage 