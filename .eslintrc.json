{
  "env": {
    "browser": true,
    "commonjs": true,
    "es2022": true,
    "node": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "rules": {
    "no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ],
    "no-useless-escape": "off"
  },
  "overrides": [
    {
      "files": ["src/**/*.js"],
      "parserOptions": {
        "sourceType": "script"
      }
    },
    {
      "files": ["tests/**/*.mjs"],
      "env": {
        "node": true
      }
    }
  ]
}
